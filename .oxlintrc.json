{
  "$schema": "./node_modules/oxlint/configuration_schema.json",
  "categories": {
    "correctness": "error",
    "perf": "error",
    "suspicious": "warn"
  },
  "options": {
    "typeAware": true,
    "typeCheck": true
  },
  "ignorePatterns": ["**/node_modules/**", "**/.moon/cache/**", "**/.output/**", "**/.vinxi/**"],
  "overrides": [
    {
      "files": ["**/vite.config.ts"],
      "rules": {
        "typescript/no-unsafe-type-assertion": "off"
      }
    }
  ]
}
