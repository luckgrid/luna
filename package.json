{
  "name": "luna",
  "private": true,
  "description": "A monorepo starter template using moonrepo, bun, solid-start, and oxc.",
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "type": "module",
  "scripts": {
    "install": "proto install && bun install --ignore-scripts && moon run web:install api:build",
    "build": "moon run :build --query \"projectLayer=application\"",
    "dev": "moon run :dev --query \"projectLayer=application\"",
    "start": "moon run :start --query \"projectLayer=application\"",
    "typecheck": "tsc --build --verbose",
    "check": "bun run lint && bun run format:check && bun run typecheck",
    "fix": "bun run lint:fix && bun run format",
    "format": "oxfmt . && moon run api:format web:format",
    "format:check": "oxfmt --list-different . && moon run api:format-check web:format-check",
    "lint": "oxlint . && moon run api:lint web:lint",
    "lint:fix": "oxlint --fix . && moon run api:lint-fix web:lint-fix",
    "clean": "moon run :clean && moon clean --all && git clean -fdx -- .cache node_modules",
    "outdated": "luna outdated",
    "update": "luna update"
  },
  "devDependencies": {
    "@luna/cli": "workspace:*",
    "@tailwindcss/cli": "^4.2.4",
    "@types/bun": "^1.3.13",
    "oxfmt": "^0.47.0",
    "oxlint": "^1.62.0",
    "oxlint-tsgolint": "^0.22.1",
    "typescript": "^6.0.3"
  },
  "packageManager": "bun@1.3.13"
}
