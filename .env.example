# PORTS
API_PORT=8080
APP_PORT=3001
WEB_PORT=3000

# HOSTS
API_HOST=api.example.com # 0.0.0.0 (.env.local)
APP_HOST=app.example.com # 0.0.0.0 (.env.local)
WEB_HOST=example.com # 0.0.0.0 (.env.local)

# URLs
API_BASE_URL=https://api.example.com # http://localhost:8080 (.env.local)
APP_BASE_URL=https://app.example.com # http://localhost:3001 (.env.local)
WEB_BASE_URL=https://example.com # http://localhost:3000 (.env.local)

# DB
DATABASE_URL=sqlite+aiosqlite:///./data.db

# AI
AI_MODEL=openai:gpt-4o-mini
OPENAI_API_KEY=your-openai-api-key-here

# DEV
DEBUG=true
